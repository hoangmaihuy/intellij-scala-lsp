<idea-plugin>
  <id>org.jetbrains.intellij-scala-lsp</id>
  <name>IntelliJ Scala LSP</name>
  <version>0.1.0</version>
  <vendor>JetBrains</vendor>
  <description>LSP server backed by IntelliJ IDEA's Scala analysis engine</description>

  <depends>com.intellij.modules.platform</depends>
  <depends>org.intellij.scala</depends>

  <extensions defaultExtensionNs="com.intellij">
    <appStarter id="scala-lsp"
                implementation="org.jetbrains.scalalsP.ScalaLspApplicationStarter"/>
    <appStarter id="scala-lsp-import"
                implementation="org.jetbrains.scalalsP.ProjectImporter"
                internal="true"/>
  </extensions>
</idea-plugin>
