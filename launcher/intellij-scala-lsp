  cat > "$ext_dir/extension.js" << EXTJS
const { LanguageClient, TransportKind } = require("vscode-languageclient/node");
const vscode = require("vscode");

let client, outputChannel, statusBarItem;

function log(msg) {
  const ts = new Date().toISOString().replace("T", " ").replace("Z", "");
  outputChannel.appendLine("[" + ts + "] " + msg);
}

function setStatus(icon, text, tooltip) {
  statusBarItem.text = "\$(" + icon + ") " + text;
  statusBarItem.tooltip = tooltip || text;
  statusBarItem.show();
}

function shortUri(uri) {
  if (!uri) return "";
  const m = uri.match(/([^/]+)\$/);
  return m ? m[1] : uri;
}

function summarizeResult(r) {
  try {
    if (r == null) return "null";
    if (Array.isArray(r)) {
      if (r.length === 0) return "[]";
      if (r[0]?.uri) return r.length + " locations [" + shortUri(typeof r[0].uri === "string" ? r[0].uri : String(r[0].uri)) + ":" + (r[0].range?.start?.line ?? "?") + "]";
      if (r[0]?.label) return r.length + " items";
      return r.length + " results";
    }
    if (r?.contents) return "hover";
    if (r?.signatures) return r.signatures.length + " signatures";
    if (r?.changes || r?.documentChanges) return "workspace edit";
    return typeof r;
  } catch { return "?"; }
}

function createLoggingMiddleware() {
  function wrap(method) {
    return async function (...args) {
      const next = args[args.length - 1], params = args[0];
      const file = params?.textDocument?.uri ? " [" + shortUri(params.textDocument.uri) + "]" : "";
      const pos = params?.position ? ":" + params.position.line + ":" + params.position.character : "";
      const start = Date.now();
      try {
        const result = await next(...args.slice(0, -1));
        log(method + file + pos + " -> " + (Date.now() - start) + "ms " + summarizeResult(result));
        return result;
      } catch (err) {
        log(method + file + pos + " -> ERROR " + (Date.now() - start) + "ms: " + (err?.message || err));
        throw err;
      }
    };
  }
  return {
    provideCompletionItem: wrap("textDocument/completion"),
    provideHover: wrap("textDocument/hover"),
    provideDefinition: wrap("textDocument/definition"),
    provideTypeDefinition: wrap("textDocument/typeDefinition"),
    provideImplementation: wrap("textDocument/implementation"),
    provideReferences: wrap("textDocument/references"),
    provideDocumentSymbols: wrap("textDocument/documentSymbol"),
    provideSignatureHelp: wrap("textDocument/signatureHelp"),
    provideDocumentFormattingEdits: wrap("textDocument/formatting"),
    provideRenameEdits: wrap("textDocument/rename"),
    provideCodeActions: wrap("textDocument/codeAction"),
  };
}

function activate(context) {
  outputChannel = vscode.window.createOutputChannel("IntelliJ Scala LSP");
  context.subscriptions.push(outputChannel);
  statusBarItem = vscode.window.createStatusBarItem(vscode.StatusBarAlignment.Left, 0);
  statusBarItem.command = "intellijScalaLsp.showOutput";
  context.subscriptions.push(statusBarItem);
  context.subscriptions.push(vscode.commands.registerCommand("intellijScalaLsp.showOutput", () => outputChannel.show()));

  log("Activating IntelliJ Scala LSP extension");
  setStatus("sync~spin", "Scala LSP: Starting", "IntelliJ Scala LSP — starting server");

  const config = vscode.workspace.getConfiguration("intellijScalaLsp");
  const launcher = config.get("launcher") || "$launcher_cmd";
  log("Launcher: " + launcher);

  client = new LanguageClient("intellijScalaLsp", "IntelliJ Scala LSP",
    { command: launcher, args: [], transport: TransportKind.stdio },
    { documentSelector: [{ scheme: "file", language: "scala" }, { scheme: "file", pattern: "**/*.scala" }, { scheme: "file", pattern: "**/*.sc" }], outputChannel, middleware: createLoggingMiddleware() }
  );
  client.onDidChangeState(({ oldState, newState }) => {
    const s = { 1: "Stopped", 2: "Starting", 3: "Running" };
    log("Client state: " + (s[oldState] || oldState) + " -> " + (s[newState] || newState));
    if (newState === 3) setStatus("sync~spin", "Scala LSP: Indexing", "IntelliJ Scala LSP — indexing project");
    else if (newState === 1) setStatus("circle-slash", "Scala LSP: Stopped", "IntelliJ Scala LSP — stopped");
    else setStatus("sync~spin", "Scala LSP: Starting", "IntelliJ Scala LSP — starting");
  });
  log("Starting language client");
  client.start().then(
    () => { log("Language client started successfully"); client.onNotification("window/logMessage", (p) => { const m = p.message || ""; log("[server] " + m); if (m.includes("Indexing project")) setStatus("sync~spin", "Scala LSP: Indexing", "IntelliJ Scala LSP — indexing project"); else if (m.includes("Indexing complete")) setStatus("check", "Scala LSP", "IntelliJ Scala LSP — ready"); }); },
    (err) => { log("ERROR: Failed to start: " + err.message); setStatus("error", "Scala LSP: Error", "Failed: " + err.message); vscode.window.showErrorMessage("IntelliJ Scala LSP failed: " + err.message); }
  );
  context.subscriptions.push(client);
}

function deactivate() { if (statusBarItem) statusBarItem.dispose(); if (client) return client.stop(); }
module.exports = { activate, deactivate };
EXTJS

  echo "Installing vscode-languageclient..."
  (cd "$ext_dir" && npm install --silent 2>&1 | tail -3)

