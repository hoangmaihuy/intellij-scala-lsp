# --- Main ---

# Handle --version and --help before setting up logging (they should be quiet)
case "${1:-}" in
  --version)
    echo "intellij-scala-lsp $LSP_VERSION (IntelliJ $INTELLIJ_BUILD)"
    exit 0
    ;;
  --help)
    echo "Usage: intellij-scala-lsp [OPTIONS]"
    echo ""
    echo "Options:"
    echo "  --daemon [projects...]    Start daemon, optionally pre-warm projects"
    echo "  --stop                    Stop the daemon"
    echo "  --install                 Download LSP JARs and SDK"
    echo "  --update                  Update to latest version"
    echo "  --setup-claude-code       Set up Claude Code plugin (installed users)"
    echo "  --setup-claude-code-dev   Set up Claude Code plugin (local dev)"
    echo "  --setup-vscode            Set up VS Code extension (installed users)"
    echo "  --setup-vscode-dev        Set up VS Code extension (local dev)"
    echo "  --import <path>           Import project (auto-detects Mill/sbt)"
    echo "  --version                 Print version info"
    echo "  --help                    Show this help"
    echo ""
    echo "Default (no args): proxy stdio to daemon (auto-starts daemon if needed)"
    exit 0
    ;;
  --setup-claude-code)
    setup_claude_code "intellij-scala-lsp"
    exit 0
    ;;
  --setup-claude-code-dev)
    if [ "$DEV_MODE" != true ]; then
      echo "ERROR: --setup-claude-code-dev must be run from the repo directory."
      echo "Use --setup-claude-code for installed users."
      exit 1
    fi
    setup_claude_code "$SCRIPT_DIR/intellij-scala-lsp"
    exit 0
    ;;
  --setup-vscode)
    setup_vscode "intellij-scala-lsp"
    exit 0
    ;;
  --setup-vscode-dev)
    if [ "$DEV_MODE" != true ]; then
      echo "ERROR: --setup-vscode-dev must be run from the repo directory."
      echo "Use --setup-vscode for installed users."
      exit 1
    fi
    setup_vscode "$SCRIPT_DIR/intellij-scala-lsp"
    exit 0
    ;;
  --import)
    PROJECT_PATH="${2:-}"
    if [ -z "$PROJECT_PATH" ]; then
      echo "ERROR: --import requires a project path argument."
      echo "Usage: intellij-scala-lsp --import <project-path>"
      exit 1
    fi
    # Resolve to absolute path
    PROJECT_PATH="$(cd "$PROJECT_PATH" 2>/dev/null && pwd)" || {
      echo "ERROR: Directory does not exist: ${2}"
      exit 1
    }
    # Detect build tool
    if [ -f "$PROJECT_PATH/build.mill" ] || [ -f "$PROJECT_PATH/build.sc" ]; then
      echo "Detected Mill project at: $PROJECT_PATH"
      if ! command -v mill >/dev/null 2>&1; then
        echo "ERROR: 'mill' not found on PATH. Install Mill: https://mill-build.org"
        exit 1
      fi
      echo "Running: mill mill.idea/ ..."
      if cd "$PROJECT_PATH" && mill mill.idea/; then
        echo "Import complete."
        exit 0
      else
        echo "ERROR: mill mill.idea/ failed with exit code $?"
        exit 1
      fi
    elif [ -f "$PROJECT_PATH/build.sbt" ]; then
      echo "Detected sbt project at: $PROJECT_PATH"
      echo "Importing sbt project..."
      # Falls through to second case block which has SDK/classpath setup
    else
      echo "ERROR: Could not detect build tool at: $PROJECT_PATH"
      echo "Expected build.sbt (sbt) or build.mill/build.sc (Mill)"
      exit 1
    fi
    ;;
esac

# Log stderr to file
mkdir -p "$(dirname "$LSP_LOG")"
exec 2> >(tee -a "$LSP_LOG" >&2)
log "=== Starting at $(date) ==="

case "${1:-}" in
  --install)
    do_install
    ;;
  --update)
    do_update
    ;;
  --stop)
    resolve_sdk
    assemble_classpath_and_flags
    exec "$JAVA" "${JVM_ARGS[@]}" -cp "$CLASSPATH" \
      org.jetbrains.scalalsP.ScalaLspMain --stop
    ;;
  --daemon)
    shift
    resolve_sdk
    assemble_classpath_and_flags
    check_for_updates
    exec "$JAVA" "${JVM_ARGS[@]}" -cp "$CLASSPATH" \
      org.jetbrains.scalalsP.ScalaLspMain --daemon "$@"
    ;;
  --import)
    # sbt import — we only reach here for sbt projects (Mill handled above)
    resolve_sdk
    assemble_classpath_and_flags
    exec "$JAVA" "${JVM_ARGS[@]}" -cp "$CLASSPATH" \
      org.jetbrains.scalalsP.ProjectImporter "$PROJECT_PATH"
    ;;
  *)
    # Connect mode: proxy to daemon, auto-start if needed
    resolve_sdk
    assemble_classpath_and_flags
    check_for_updates
    if daemon_running; then
      DAEMON_PORT=$(cat "$CACHE_DIR/daemon.port")
      log "Connecting to daemon on port $DAEMON_PORT"
      proxy_stdio_to_tcp "$DAEMON_PORT"
    else
      start_daemon_background "$@"
      if wait_for_port_file 60; then
        DAEMON_PORT=$(cat "$CACHE_DIR/daemon.port")
        log "Daemon started, connecting on port $DAEMON_PORT"
        proxy_stdio_to_tcp "$DAEMON_PORT"
      else
        log "ERROR: Daemon failed to start within 60s. Check $LSP_LOG"
        exit 1
      fi
    fi
    ;;
esac
